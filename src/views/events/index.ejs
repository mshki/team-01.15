<section class="mb-5 p-6 border border-slate-200 rounded-2xl bg-gradient-to-b from-white to-slate-50 shadow-lg">
  <h1 class="text-3xl font-bold text-slate-900 mb-3">Browse Events</h1>
  <p class="text-slate-500">
    Filter published events by timeframe and category.
  </p>
</section>

<% if (pageError) { %>
  <%- include("../partials/error", { message: pageError }) %>
<% } %>

<section class="mb-5 p-6 border border-slate-200 rounded-2xl bg-white shadow-lg">
  <h2 class="text-xl font-semibold mb-4">Filter Events</h2>

  <form method="get" action="/events" class="grid gap-4 md:grid-cols-3">
    <div>
      <label for="timeframe" class="block text-sm font-medium mb-1">Timeframe</label>
      <select
        id="timeframe"
        name="timeframe"
        class="w-full px-3 py-2.5 border border-slate-300 rounded-xl bg-white"
      >
        <option value="all" <%= timeframe === "all" ? "selected" : "" %>>All upcoming</option>
        <option value="week" <%= timeframe === "week" ? "selected" : "" %>>This week</option>
        <option value="weekend" <%= timeframe === "weekend" ? "selected" : "" %>>This weekend</option>
      </select>
    </div>

    <div>
      <label for="category" class="block text-sm font-medium mb-1">Category</label>
      <input
        id="category"
        name="category"
        type="text"
        value="<%= category ?? "" %>"
        class="w-full px-3 py-2.5 border border-slate-300 rounded-xl bg-white"
      />
    </div>

    <div class="flex items-end gap-2">
      <button
        type="submit"
        class="px-4 py-2.5 rounded-lg bg-blue-600 text-white font-medium hover:bg-blue-700 cursor-pointer"
      >
        Apply Filters
      </button>

      <a
        href="/events"
        class="px-4 py-2.5 rounded-lg bg-white text-slate-700 border border-slate-300 font-medium no-underline hover:bg-slate-50"
      >
        Clear
      </a>
      </div>
  </form>
</section>
<section class="grid gap-4">
  <% if (!events || events.length === 0) { %>
    <div class="p-6 border border-slate-200 rounded-2xl bg-white shadow-lg">
      <p class="text-slate-500 mb-0">No events match the current filters.</p>
    </div>
  <% } %>

  <% events.forEach((event) => { %>

    <!-- functions -->
    <%
    const goingCount = event.attendees.filter(a => a.rsvpStatus === 'GOING').length;
    const waitlistedCount = event.attendees.filter(a => a.rsvpStatus === 'WAITLISTED').length;

    const isAdmin = session.authenticatedUser?.role === 'admin';
    const isOrganizer = event.organizerId === session.authenticatedUser?.userId;
    const isMember = session.authenticatedUser?.role === 'user';

    const canEdit = (isAdmin || isOrganizer) && event.status !== 'CANCELLED' && event.status !== 'CONCLUDED';
    const canRsvp = !isAdmin && !isOrganizer && event.status === 'PUBLISHED';

    const userRsvp = session.authenticatedUser
      ? event.attendees.find(a => a.userId === session.authenticatedUser.userId) ?? null
      : null;

    const isGoing = userRsvp?.rsvpStatus === 'GOING';
    const isWaitlisted = userRsvp?.rsvpStatus === 'WAITLISTED';
    const eventIsFull = event.capacity !== null && goingCount >= event.capacity;

    const rsvpButtonLabel = userRsvp
      ? (isGoing ? 'Cancel RSVP' : 'Leave waitlist')
      : (eventIsFull ? 'Join waitlist' : 'RSVP to this event');

    const rsvpHelpText = userRsvp
      ? (isGoing
          ? 'You are currently marked as going.'
          : 'You are currently on the waitlist.')
      : (eventIsFull
          ? 'This event is full, so new RSVPs will be waitlisted.'
          : "You haven't RSVP'd yet.");

    const statusLabels = {
      PUBLISHED: 'Published',
      DRAFT: 'Draft',
      CANCELLED: 'Cancelled',
      CONCLUDED: 'Concluded',
    };

    const statusColors = {
      PUBLISHED: 'bg-green-100 text-green-800',
      DRAFT: 'bg-yellow-100 text-yellow-800',
      CANCELLED: 'bg-red-100 text-red-800',
      CONCLUDED: 'bg-slate-100 text-slate-600',
    };

    function formatDatetime(d) {
      return new Date(d).toLocaleString('en-US', {
        weekday: 'short',
        month: 'short',
        day: 'numeric',
        year: 'numeric',
        hour: 'numeric',
        minute: '2-digit',
      });
    }
    %>
    <!-- end functions -->
    <article class="p-6 border border-slate-200 rounded-2xl bg-white shadow-lg">
      <div class="flex items-start justify-between gap-4 flex-wrap">
        <div>
          <h3 class="text-xl font-semibold text-slate-900 mb-1">
            <a
              href="/events/<%= event.id %>"
              class="no-underline text-slate-900 hover:text-blue-700"
            >
              <%= event.title %>
            </a>
          </h3>

          <p class="text-slate-500 text-sm mb-2"><%= event.location %></p>

          <% if (event.category) { %>
            <p class="text-sm text-slate-500 mb-2">Category: <%= event.category %></p>
          <% } %>

          <p class="text-slate-700 mb-0"><%= event.description %></p>
        </div>

        <% if (isAdmin || isOrganizer) { %>
          <% if (canEdit) { %>
          <div class="mt-4">
            <a
              href="/events/<%= event.id %>/edit"
              class="inline-block px-4 py-2.5 rounded-lg bg-blue-600 text-white font-medium hover:bg-blue-700 no-underline text-sm"
            >
              Edit event
            </a>
          </div>
          <% } %>
        <% } %>

        <div class="mt-5 grid gap-4 md:grid-cols-2">
          <% if (canRsvp) { %>
            <%- include("./partials/rsvp-panel", {
              event,
              session,
              idSuffix: event.id,
              oob: false
            }) %>
          <% } %>
      
          <%- include("./partials/attendance-panel", {
            event,
            idSuffix: event.id,
            oob: false
          }) %>
        </div>


        <span class="inline-block px-3 py-1 rounded-full text-sm font-medium bg-green-100 text-green-800">
          <%= event.status %>
        </span>
      </div>
    </article>
  <% }) %>
</section>