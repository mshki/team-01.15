<section class="mb-5 p-6 border border-slate-200 rounded-2xl bg-gradient-to-b from-white to-slate-50 shadow-lg">
  <h1 class="text-3xl font-bold text-slate-900 mb-3">Browse Events</h1>
  <p class="text-slate-500">
    Filter published events by timeframe and category.
  </p>
</section>

<% if (pageError) { %>
  <%- include("../partials/error", { message: pageError }) %>
<% } %>

<section class="mb-5 p-6 border border-slate-200 rounded-2xl bg-white shadow-lg">
  <h2 class="text-xl font-semibold mb-4">Filter Events</h2>

  <form method="get" action="/events" class="grid gap-4 md:grid-cols-3">
    <div>
      <label for="timeframe" class="block text-sm font-medium mb-1">Timeframe</label>
      <select
        id="timeframe"
        name="timeframe"
        class="w-full px-3 py-2.5 border border-slate-300 rounded-xl bg-white"
      >
        <option value="all" <%= timeframe === "all" ? "selected" : "" %>>All upcoming</option>
        <option value="week" <%= timeframe === "week" ? "selected" : "" %>>This week</option>
        <option value="weekend" <%= timeframe === "weekend" ? "selected" : "" %>>This weekend</option>
      </select>
    </div>

    <div>
      <label for="category" class="block text-sm font-medium mb-1">Category</label>
      <input
        id="category"
        name="category"
        type="text"
        value="<%= category ?? "" %>"
        class="w-full px-3 py-2.5 border border-slate-300 rounded-xl bg-white"
      />
    </div>

    <div class="flex items-end">
      <button
        type="submit"
        class="px-4 py-2.5 rounded-lg bg-blue-600 text-white font-medium hover:bg-blue-700 cursor-pointer"
      >
        Apply Filters
      </button>
    </div>
  </form>
</section>
<section class="grid gap-4">
  <% if (!events || events.length === 0) { %>
    <div class="p-6 border border-slate-200 rounded-2xl bg-white shadow-lg">
      <p class="text-slate-500 mb-0">No events match the current filters.</p>
    </div>
  <% } %>

  <% events.forEach((event) => { %>
    <article class="p-6 border border-slate-200 rounded-2xl bg-white shadow-lg">
      <div class="flex items-start justify-between gap-4 flex-wrap">
        <div>
          <h3 class="text-xl font-semibold text-slate-900 mb-1">
            <a
              href="/events/<%= event.id %>"
              class="no-underline text-slate-900 hover:text-blue-700"
            >
              <%= event.title %>
            </a>
          </h3>

          <p class="text-slate-500 text-sm mb-2"><%= event.location %></p>

          <% if (event.category) { %>
            <p class="text-sm text-slate-500 mb-2">Category: <%= event.category %></p>
          <% } %>

          <p class="text-slate-700 mb-0"><%= event.description %></p>
        </div>

        <span class="inline-block px-3 py-1 rounded-full text-sm font-medium bg-green-100 text-green-800">
          <%= event.status %>
        </span>
      </div>
    </article>
  <% }) %>
</section>