<section class="mb-5 p-6 border border-slate-200 rounded-2xl bg-gradient-to-b from-white to-slate-50 shadow-lg">
  <h1 class="text-3xl font-bold text-slate-900 mb-3">Browse Events</h1>
  <p class="text-slate-500">
    Filter published events by timeframe and category.
  </p>
</section>

<% if (pageError) { %>
  <%- include("../partials/error", { message: pageError }) %>
<% } %>

<%# ── Search hero (Sprint 4) ── %>
<section class="mb-5 p-6 border border-slate-200 rounded-2xl bg-white shadow-lg">
  <form
    method="get"
    action="/events/search"
    class="flex flex-col sm:flex-row gap-3"
    x-data="{ query: '' }"
  >
    <label for="event-search" class="sr-only">Search events</label>

    <div class="relative flex-1">
      <%# Search icon (left) %>
      <svg
        class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-400 pointer-events-none"
        fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"
      >
        <circle cx="11" cy="11" r="7"/>
        <path d="m21 21-4.3-4.3"/>
      </svg>

      <input
        id="event-search"
        name="q"
        type="text"
        placeholder="Search events by title, location, or category..."
        x-model="query"
        class="w-full pl-12 pr-12 py-3.5 text-base border border-slate-300 rounded-xl bg-white shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent placeholder:text-slate-400"
      />

      <%# Alpine clear-X — only renders when field has content %>
      <button
        type="button"
        x-show="query.length > 0"
        x-cloak
        @click="query = ''"
        aria-label="Clear search"
        class="absolute right-3 top-1/2 -translate-y-1/2 w-7 h-7 flex items-center justify-center rounded-full text-slate-400 hover:bg-slate-100 hover:text-slate-600 transition cursor-pointer"
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path d="M6 6l12 12M18 6L6 18"/>
        </svg>
      </button>
    </div>

    <button
      type="submit"
      class="px-6 py-3.5 rounded-xl bg-blue-600 text-white text-base font-medium hover:bg-blue-700 cursor-pointer transition shadow-sm"
    >
      Search
    </button>
  </form>
</section>

<section class="mb-5 p-6 border border-slate-200 rounded-2xl bg-white shadow-lg">
  <h2 class="text-xl font-semibold mb-4">Filter Events</h2>

  <form
    method="get"
    action="/events"
    hx-get="/events"
    hx-target="#event-list"
    hx-swap="outerHTML"
    hx-push-url="true"
    class="grid gap-4 md:grid-cols-3"
>
    <div>
      <label for="timeframe" class="block text-sm font-medium mb-1">Timeframe</label>
      <select
        id="timeframe"
        name="timeframe"
        class="w-full px-3 py-2.5 border border-slate-300 rounded-xl bg-white"
      >
        <option value="all" <%= timeframe === "all" ? "selected" : "" %>>All upcoming</option>
        <option value="week" <%= timeframe === "week" ? "selected" : "" %>>This week</option>
        <option value="weekend" <%= timeframe === "weekend" ? "selected" : "" %>>This weekend</option>
      </select>
    </div>

    <div>
      <label for="category" class="block text-sm font-medium mb-1">Category</label>
      <input
        id="category"
        name="category"
        type="text"
        value="<%= category ?? "" %>"
        class="w-full px-3 py-2.5 border border-slate-300 rounded-xl bg-white"
      />
    </div>

    <div class="flex items-end gap-2">
      <button
        type="submit"
        class="px-4 py-2.5 rounded-lg bg-blue-600 text-white font-medium hover:bg-blue-700 cursor-pointer"
      >
        Apply Filters
      </button>

      <a
        href="/events"
        class="px-4 py-2.5 rounded-lg bg-white text-slate-700 border border-slate-300 font-medium no-underline hover:bg-slate-50"
      >
        Clear
      </a>
      </div>
  </form>
</section>
<%- include("./partials/event-list", {
  events,
  session
}) %>