<!-- views/events/show.ejs -->
<%
  // goingCount, waitlistedCount, userRsvp, and queuePosition are provided by
  // the controller so the waitlist service is the single source of truth for
  // "who's #1 in line". Do not recompute them here.
  const isAdmin = session.authenticatedUser?.role === 'admin';
  const isOrganizer = event.organizerId === session.authenticatedUser?.userId;
  const isMember = session.authenticatedUser?.role === 'user';

  const isWaitlisted = !!userRsvp && userRsvp.rsvpStatus === 'WAITLISTED';

  const canEdit = (isAdmin || isOrganizer) && event.status !== 'CANCELLED' && event.status !== 'CONCLUDED';

  const statusLabels = {
    PUBLISHED: 'Published',
    DRAFT: 'Draft',
    CANCELLED: 'Cancelled',
    CONCLUDED: 'Concluded',
  };

  const statusColors = {
    PUBLISHED: 'bg-green-100 text-green-800',
    DRAFT: 'bg-yellow-100 text-yellow-800',
    CANCELLED: 'bg-red-100 text-red-800',
    CONCLUDED: 'bg-slate-100 text-slate-600',
  };

  function formatDatetime(d) {
    return new Date(d).toLocaleString('en-US', {
      weekday: 'short',
      month: 'short',
      day: 'numeric',
      year: 'numeric',
      hour: 'numeric',
      minute: '2-digit',
    });
  }
%>

<div class="mb-5 p-6 border border-slate-200 rounded-2xl bg-gradient-to-b from-white to-slate-50 shadow-lg">
  <div class="flex items-start justify-between gap-4 flex-wrap mb-2">
    <h1 class="text-3xl font-bold text-slate-900"><%= event.title %></h1>
    <div class="flex items-center gap-2 flex-wrap">
      <% if (isWaitlisted && queuePosition) { %>
        <span class="inline-block px-3 py-1 rounded-full text-sm font-medium bg-amber-100 text-amber-800">
          Waitlisted · #<%= queuePosition %>
        </span>
      <% } %>
    </div>
  </div>
  <p class="text-slate-500 text-sm">
    Organized by <strong class="text-slate-700"><%= organizerName %></strong>
  </p>
</div>

<% if (typeof pageError !== 'undefined' && pageError) { %>
  <%- include("../partials/error", { message: pageError }) %>
<% } %>

<div class="grid gap-5 md:grid-cols-3">
  <div class="md:col-span-2 flex flex-col gap-5">
    <section class="p-6 border border-slate-200 rounded-2xl bg-white shadow-lg">
      <h2 class="text-lg font-semibold text-slate-900 mb-3">About this event</h2>
      <p class="text-slate-700 whitespace-pre-line"><%= event.description %></p>
    </section>

    <%- include("./partials/lifecycle-controls", {
      event,
      session,
      pageError: null
    }) %>

    <%- include("./partials/event-interaction-region", {
      event,
      session,
      isMember,
      isAdmin,
      isOrganizer,
      htmx: false
    }) %>
  </div>

  <aside class="flex flex-col gap-4">
    <section id="attendance-panel" class="p-5 border border-slate-200 rounded-2xl bg-white shadow-lg">
      <h2 class="text-sm font-semibold text-slate-500 uppercase tracking-wide mb-4">Details</h2>

      <dl class="flex flex-col gap-3 text-sm">
        <div>
          <dt class="font-medium text-slate-900 mb-0.5">Date &amp; time</dt>
          <dd class="text-slate-600"><%= formatDatetime(event.startDatetime) %></dd>
          <dd class="text-slate-400 text-xs mt-0.5">to <%= formatDatetime(event.endDatetime) %></dd>
        </div>

        <div>
          <dt class="font-medium text-slate-900 mb-0.5">Location</dt>
          <dd class="text-slate-600"><%= event.location %></dd>
        </div>

        <% if (event.category) { %>
        <div>
          <dt class="font-medium text-slate-900 mb-0.5">Category</dt>
          <dd class="text-slate-600"><%= event.category %></dd>
        </div>
        <% } %>

        <div>
          <dt class="font-medium text-slate-900 mb-0.5">Attendance</dt>

          <% if (event.capacity !== null) { %>
            <dd class="text-slate-600">
              <%= goingCount %> / <%= event.capacity %> going
              <% if (waitlistedCount > 0) { %>
                · <%= waitlistedCount %> waitlisted
              <% } %>
            </dd>

            <dd class="mt-1.5">
              <% const fillPct = Math.min(100, Math.round((goingCount / event.capacity) * 100)); %>
              <div class="w-full h-1.5 bg-slate-100 rounded-full overflow-hidden">
                <div
                  class="h-full rounded-full <%= goingCount >= event.capacity ? 'bg-red-500' : 'bg-blue-500' %>"
                  style="width: <%= fillPct %>%"
                ></div>
              </div>
            </dd>
          <% } else { %>
            <dd class="text-slate-600">
              <%= goingCount %> going
              <% if (waitlistedCount > 0) { %>
                · <%= waitlistedCount %> waitlisted
              <% } %>
              · unlimited capacity
            </dd>
          <% } %>

          <% if (isWaitlisted && queuePosition) { %>
            <dd class="mt-1.5 text-xs text-amber-700">
              You're #<%= queuePosition %> in line — we'll auto-promote you when a spot opens up.
            </dd>
          <% } %>
        </div>
      </dl>
    </section>
  </aside>
</div>