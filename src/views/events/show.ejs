<!-- views/events/show.ejs -->
<%
  // NOTE: goingCount, waitlistedCount, userRsvp, and queuePosition are provided
  // by EventController.showEventDetails. userRsvp is the current user's active
  // RSVP (GOING or WAITLISTED) or null. queuePosition is 1-based or null.

  const isAdmin = session.authenticatedUser?.role === 'admin';
  const isOrganizer = event.organizerId === session.authenticatedUser?.userId;
  const isMember = session.authenticatedUser?.role === 'user';

  const canEdit = (isAdmin || isOrganizer) && event.status !== 'CANCELLED' && event.status !== 'CONCLUDED';
  const canRsvp = isMember && event.status === 'PUBLISHED';

  const isGoing = userRsvp?.rsvpStatus === 'GOING';
  const isWaitlisted = userRsvp?.rsvpStatus === 'WAITLISTED';
  const eventIsFull = event.capacity !== null && goingCount >= event.capacity;

  const rsvpButtonLabel = userRsvp
    ? (isGoing ? 'Cancel RSVP' : 'Leave waitlist')
    : (eventIsFull ? 'Join waitlist' : 'RSVP to this event');

  const rsvpHelpText = userRsvp
    ? (isGoing
        ? 'You are currently marked as going.'
        : (queuePosition
            ? `You are #${queuePosition} on the waitlist.`
            : 'You are currently on the waitlist.'))
    : (eventIsFull
        ? 'This event is full, so new RSVPs will be waitlisted.'
        : "You haven't RSVP'd yet.");

  const statusLabels = {
    PUBLISHED: 'Published',
    DRAFT: 'Draft',
    CANCELLED: 'Cancelled',
    CONCLUDED: 'Concluded',
  };

  const statusColors = {
    PUBLISHED: 'bg-green-100 text-green-800',
    DRAFT: 'bg-yellow-100 text-yellow-800',
    CANCELLED: 'bg-red-100 text-red-800',
    CONCLUDED: 'bg-slate-100 text-slate-600',
  };

  function formatDatetime(d) {
    return new Date(d).toLocaleString('en-US', {
      weekday: 'short',
      month: 'short',
      day: 'numeric',
      year: 'numeric',
      hour: 'numeric',
      minute: '2-digit',
    });
  }
%>

<div class="mb-5 p-6 border border-slate-200 rounded-2xl bg-gradient-to-b from-white to-slate-50 shadow-lg">
  <div class="flex items-start justify-between gap-4 flex-wrap mb-2">
    <h1 class="text-3xl font-bold text-slate-900"><%= event.title %></h1>
    <span class="inline-block px-3 py-1 rounded-full text-sm font-medium <%= statusColors[event.status] %>">
      <%= statusLabels[event.status] %>
    </span>
  </div>
  <p class="text-slate-500 text-sm">
    Organized by <strong class="text-slate-700"><%= organizerName %></strong>
  </p>
</div>

<% if (typeof pageError !== 'undefined' && pageError) { %>
  <%- include("../partials/error", { message: pageError }) %>
<% } %>

<div class="grid gap-5 md:grid-cols-3">
  <div class="md:col-span-2 flex flex-col gap-5">
    <section class="p-6 border border-slate-200 rounded-2xl bg-white shadow-lg">
      <h2 class="text-lg font-semibold text-slate-900 mb-3">About this event</h2>
      <p class="text-slate-700 whitespace-pre-line"><%= event.description %></p>
    </section>

    <% if (isAdmin || isOrganizer) { %>
      <section class="p-6 border border-slate-200 rounded-2xl bg-white shadow-lg">
        <h2 class="text-lg font-semibold text-slate-900 mb-4">Manage event</h2>

        <% if (canEdit) { %>
          <div class="flex flex-wrap gap-3">
            <a
              href="/events/<%= event.id %>/edit"
              class="px-4 py-2.5 rounded-lg bg-blue-600 text-white font-medium hover:bg-blue-700 no-underline text-sm"
            >
              Edit event
            </a>

            <% if (event.status === 'DRAFT') { %>
              <form method="post" action="/events/<%= event.id %>/publish">
                <button
                  type="submit"
                  class="px-4 py-2.5 rounded-lg bg-green-600 text-white font-medium hover:bg-green-700 cursor-pointer text-sm"
                >
                  Publish event
                </button>
              </form>
            <% } %>

            <% if (event.status === 'PUBLISHED') { %>
              <form method="post" action="/events/<%= event.id %>/cancel">
                <button
                  type="submit"
                  class="px-4 py-2.5 rounded-lg bg-white text-red-700 border border-red-300 font-medium hover:bg-red-50 cursor-pointer text-sm"
                  onclick="return confirm('Cancel this event? This cannot be undone.')"
                >
                  Cancel event
                </button>
              </form>
            <% } %>
          </div>
        <% } else { %>
          <p class="text-sm text-slate-500">
            This event can no longer be edited because it has been cancelled or concluded.
          </p>
        <% } %>
      </section>
    <% } %>

    <% if (canRsvp) { %>
      <section id="rsvp-panel" class="p-6 border border-slate-200 rounded-2xl bg-white shadow-lg">
        <h2 class="text-lg font-semibold text-slate-900 mb-3">Your RSVP</h2>

        <% if (isWaitlisted && queuePosition) { %>
          <div class="mb-4 flex items-center gap-3 p-3 rounded-lg bg-amber-50 border border-amber-200">
            <span class="flex items-center justify-center w-10 h-10 rounded-full bg-amber-500 text-white font-bold text-lg">
              #<%= queuePosition %>
            </span>
            <div class="text-sm">
              <p class="font-medium text-amber-900">You're #<%= queuePosition %> on the waitlist</p>
              <p class="text-amber-700 text-xs">
                You'll be promoted automatically when someone going cancels their RSVP.
              </p>
            </div>
          </div>
        <% } else { %>
          <p class="text-slate-600 text-sm mb-4"><%= rsvpHelpText %></p>
        <% } %>

        <form id="rsvp-form" method="post" action="/events/<%= event.id %>/rsvp/toggle">
          <button
            type="submit"
            class="px-4 py-2.5 rounded-lg font-medium cursor-pointer text-sm
              <%= isGoing || isWaitlisted
                ? 'bg-white text-slate-700 border border-slate-300 hover:bg-slate-50'
                : 'bg-blue-600 text-white hover:bg-blue-700' %>"
          >
            <%= rsvpButtonLabel %>
          </button>
        </form>
      </section>
    <% } %>
  </div>

  <aside class="flex flex-col gap-4">
    <section id="attendance-panel" class="p-5 border border-slate-200 rounded-2xl bg-white shadow-lg">
      <h2 class="text-sm font-semibold text-slate-500 uppercase tracking-wide mb-4">Details</h2>

      <dl class="flex flex-col gap-3 text-sm">
        <div>
          <dt class="font-medium text-slate-900 mb-0.5">Date &amp; time</dt>
          <dd class="text-slate-600"><%= formatDatetime(event.startDatetime) %></dd>
          <dd class="text-slate-400 text-xs mt-0.5">to <%= formatDatetime(event.endDatetime) %></dd>
        </div>

        <div>
          <dt class="font-medium text-slate-900 mb-0.5">Location</dt>
          <dd class="text-slate-600"><%= event.location %></dd>
        </div>

        <div>
          <dt class="font-medium text-slate-900 mb-0.5">Attendance</dt>

          <% if (event.capacity !== null) { %>
            <dd class="text-slate-600">
              <%= goingCount %> / <%= event.capacity %> going
              <% if (waitlistedCount > 0) { %>
                · <%= waitlistedCount %> waitlisted<% if (isWaitlisted && queuePosition) { %> (you're #<%= queuePosition %>)<% } %>
              <% } %>
            </dd>

            <dd class="mt-1.5">
              <div class="w-full h-1.5 bg-slate-100 rounded-full overflow-hidden">
                <div
                  class="h-full rounded-full <%= goingCount >= event.capacity ? 'bg-red-500' : 'bg-blue-500' %>"
                  style="width: <%= Math.min(100, Math.round((goingCount / event.capacity) * 100)) %>%"
                ></div>
              </div>
            </dd>
          <% } else { %>
            <dd class="text-slate-600">
              <%= goingCount %> going
              <% if (waitlistedCount > 0) { %>
                · <%= waitlistedCount %> waitlisted<% if (isWaitlisted && queuePosition) { %> (you're #<%= queuePosition %>)<% } %>
              <% } %>
              · unlimited capacity
            </dd>
          <% } %>
        </div>
      </dl>
    </section>
  </aside>
</div>

<script>
  (() => {
    document.addEventListener('submit', async (event) => {
      const form = event.target;
      if (!(form instanceof HTMLFormElement) || form.id !== 'rsvp-form') return;

      event.preventDefault();

      const submitButton = form.querySelector('button[type="submit"]');
      if (submitButton) submitButton.disabled = true;

      try {
        const response = await fetch(form.action, {
          method: 'POST',
          body: new FormData(form),
          credentials: 'same-origin',
          headers: {
            'X-Requested-With': 'XMLHttpRequest',
          },
        });

        const html = await response.text();
        const doc = new DOMParser().parseFromString(html, 'text/html');

        const newRsvpPanel = doc.getElementById('rsvp-panel');
        const newAttendancePanel = doc.getElementById('attendance-panel');

        if (newRsvpPanel && document.getElementById('rsvp-panel')) {
          document.getElementById('rsvp-panel').outerHTML = newRsvpPanel.outerHTML;
        }

        if (newAttendancePanel && document.getElementById('attendance-panel')) {
          document.getElementById('attendance-panel').outerHTML = newAttendancePanel.outerHTML;
        }

        if (!newRsvpPanel || !newAttendancePanel) {
          window.location.reload();
        }
      } catch (err) {
        window.location.reload();
      } finally {
        if (submitButton) submitButton.disabled = false;
      }
    });
  })();
</script>