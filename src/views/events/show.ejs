<!-- views/events/show.ejs -->
<%
  // goingCount, waitlistedCount, userRsvp, and queuePosition are provided by
  // the controller so the waitlist service is the single source of truth for
  // "who's #1 in line". Do not recompute them here.
  const isAdmin = session.authenticatedUser?.role === 'admin';
  const isOrganizer = event.organizerId === session.authenticatedUser?.userId;
  const isMember = session.authenticatedUser?.role === 'user';

  const isWaitlisted = !!userRsvp && userRsvp.rsvpStatus === 'WAITLISTED';

  const canEdit = (isAdmin || isOrganizer) && event.status !== 'CANCELLED' && event.status !== 'CONCLUDED';

  const statusLabels = {
    PUBLISHED: 'Published',
    DRAFT: 'Draft',
    CANCELLED: 'Cancelled',
    CONCLUDED: 'Concluded',
  };

  const statusColors = {
    PUBLISHED: 'bg-amber-100 text-amber-800 border-amber-200',
    DRAFT: 'bg-yellow-100 text-yellow-800 border-yellow-200',
    CANCELLED: 'bg-red-100 text-red-700 border-red-200',
    CONCLUDED: 'bg-stone-100 text-stone-600 border-stone-200',
  };

  function formatDatetime(d) {
    return new Date(d).toLocaleString('en-US', {
      weekday: 'short',
      month: 'short',
      day: 'numeric',
      year: 'numeric',
      hour: 'numeric',
      minute: '2-digit',
    });
  }
%>

<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&display=swap" />

<div class="font-[Nunito,sans-serif] flex flex-col gap-5">

  <%# ── Header ── %>
  <div class="p-6 border-2 border-amber-200 rounded-2xl bg-gradient-to-br from-yellow-50 to-amber-100 shadow-lg overflow-hidden">
    <div class="flex items-end justify-between gap-4 flex-wrap">
      <div class="flex-1">
        <div class="flex items-center gap-3 flex-wrap mb-2">
          <h1 class="text-3xl font-extrabold text-amber-900"><%= event.title %></h1>
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold border <%= statusColors[event.status] %>">
            <%= statusLabels[event.status] %>
          </span>
          <% if (isWaitlisted && queuePosition) { %>
            <span class="inline-flex items-center gap-1.5 pl-2.5 pr-2 py-0.5 rounded-full text-xs font-bold bg-orange-100 text-orange-800 border border-orange-200">
              <svg class="w-3.5 h-3.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/>
              </svg>
              Waitlisted · #<%= queuePosition %>
            </span>
          <% } %>
        </div>

        <p class="text-amber-700 text-sm mb-3">
          Organized by <strong class="text-amber-900"><%= organizerName %></strong>
        </p>

        <% if (canEdit) { %>
          <a
            href="/events/<%= event.id %>/edit"
            class="inline-flex items-center px-4 py-2 rounded-xl bg-amber-800 text-yellow-50 text-sm font-bold hover:bg-amber-900 transition no-underline shadow-sm"
          >
            Edit Event
          </a>
        <% } %>
      </div>

      <%# purin1 — group scene — anchored to header bottom-right %>
      <img src="/purin1.png" alt="Pompompurin"
        class="w-36 md:w-48 shrink-0 drop-shadow-md self-end hidden sm:block" />
    </div>
  </div>

  <% if (typeof pageError !== 'undefined' && pageError) { %>
    <%- include("../partials/error", { message: pageError }) %>
  <% } %>

  <div class="grid gap-5 md:grid-cols-3">
    <%# ── Main column ── %>
    <div class="md:col-span-2 flex flex-col gap-5">
      <section class="p-6 border-2 border-amber-100 rounded-2xl bg-white shadow-md">
        <h2 class="text-lg font-extrabold text-amber-900 mb-3">About this event</h2>
        <p class="text-slate-700 whitespace-pre-line leading-relaxed"><%= event.description %></p>
      </section>

      <%- include("./partials/lifecycle-controls", {
        event,
        session,
        pageError: null
      }) %>

      <%- include("./partials/event-interaction-region", {
        event,
        session,
        isMember,
        isAdmin,
        isOrganizer,
        htmx: false
      }) %>
    </div>

    <%# ── Sidebar ── %>
    <aside class="flex flex-col gap-4">
      <section id="attendance-panel" class="border-2 border-amber-100 rounded-2xl bg-white shadow-md overflow-hidden">
        <%# Amber stripe %>
        <div class="h-1.5 bg-gradient-to-r from-amber-300 via-yellow-400 to-amber-300"></div>

        <div class="p-5">
          <h2 class="text-xs font-extrabold text-amber-500 uppercase tracking-widest mb-4">Details</h2>

          <dl class="flex flex-col text-sm">

            <%# Date & time with Alpine relative label %>
            <div
              class="py-3"
              x-data="{
                rel(iso) {
                  const diff = new Date(iso) - Date.now();
                  const abs  = Math.abs(diff);
                  const mins = Math.round(abs / 60000);
                  const hrs  = Math.round(abs / 3600000);
                  const days = Math.round(abs / 86400000);
                  const future = diff > 0;
                  if (abs < 60000)    return 'just now';
                  if (abs < 3600000)  return (future ? 'in ' : '') + mins + ' min' + (mins !== 1 ? 's' : '') + (!future ? ' ago' : '');
                  if (abs < 86400000) return (future ? 'in ' : '') + hrs  + ' hr'  + (hrs  !== 1 ? 's' : '') + (!future ? ' ago' : '');
                  if (days === 1)     return future ? 'tomorrow' : 'yesterday';
                  return (future ? 'in ' : '') + days + ' days' + (!future ? ' ago' : '');
                }
              }"
            >
              <dt class="font-bold text-amber-900 mb-1 flex items-center gap-1.5">
                <svg class="w-3.5 h-3.5 text-amber-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/>
                </svg>
                Date &amp; time
              </dt>
              <dd class="text-slate-700"><%= formatDatetime(event.startDatetime) %></dd>
              <dd class="text-amber-500 text-xs mt-0.5 font-semibold" x-cloak x-text="rel('<%= event.startDatetime %>')"></dd>
              <dd class="text-slate-400 text-xs mt-1">to <%= formatDatetime(event.endDatetime) %></dd>
              <dd class="text-amber-400 text-xs mt-0.5" x-cloak x-text="'ends ' + rel('<%= event.endDatetime %>')"></dd>
            </div>

            <div class="border-t-2 border-amber-50 py-3">
              <dt class="font-bold text-amber-900 mb-1 flex items-center gap-1.5">
                <svg class="w-3.5 h-3.5 text-amber-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/><circle cx="12" cy="9" r="2.5"/>
                </svg>
                Location
              </dt>
              <dd class="text-slate-700"><%= event.location %></dd>
            </div>

            <% if (event.category) { %>
            <div class="border-t-2 border-amber-50 py-3">
              <dt class="font-bold text-amber-900 mb-1 flex items-center gap-1.5">
                <svg class="w-3.5 h-3.5 text-amber-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path d="M4 6h16M4 10h16M4 14h8"/>
                </svg>
                Category
              </dt>
              <dd class="text-slate-700"><%= event.category %></dd>
            </div>
            <% } %>

            <div class="border-t-2 border-amber-50 py-3">
              <dt class="font-bold text-amber-900 mb-1 flex items-center gap-1.5">
                <svg class="w-3.5 h-3.5 text-amber-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/>
                </svg>
                Attendance
              </dt>

              <% if (event.capacity !== null) { %>
                <dd class="text-slate-700">
                  <%= goingCount %> / <%= event.capacity %> going
                  <% if (waitlistedCount > 0) { %>· <%= waitlistedCount %> waitlisted<% } %>
                </dd>
                <dd class="mt-2">
                  <% const fillPct = Math.min(100, Math.round((goingCount / event.capacity) * 100)); %>
                  <div class="w-full h-2 bg-amber-100 rounded-full overflow-hidden">
                    <div
                      class="h-full rounded-full transition-all <%= goingCount >= event.capacity ? 'bg-red-400' : 'bg-amber-400' %>"
                      style="width: <%= fillPct %>%"
                    ></div>
                  </div>
                  <p class="text-xs text-amber-500 mt-1 font-semibold"><%= fillPct %>% full</p>
                </dd>
              <% } else { %>
                <dd class="text-slate-700">
                  <%= goingCount %> going
                  <% if (waitlistedCount > 0) { %>· <%= waitlistedCount %> waitlisted<% } %>
                  · unlimited capacity
                </dd>
              <% } %>

              <% if (isWaitlisted && queuePosition) { %>
                <dd class="mt-2 text-xs text-orange-700 bg-orange-50 rounded-xl px-2.5 py-1.5 border border-orange-100">
                  You're #<%= queuePosition %> in line — we'll auto-promote you when a spot opens up.
                </dd>
              <% } %>
            </div>

          </dl>

          <%# purin2 — happy jumping Purin — sits at the bottom of the sidebar %>
          <div class="flex justify-end mt-2">
            <img src="/purin2.png" alt="Pompompurin"
              class="w-24 drop-shadow-sm" />
          </div>
        </div>
      </section>
    </aside>
  </div>

</div>
