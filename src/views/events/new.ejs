<section class="mb-5 p-6 border border-slate-200 rounded-2xl bg-gradient-to-b from-white to-slate-50 shadow-lg">
  <h1 class="text-3xl font-bold text-slate-900 mb-1">Create New Event</h1>
  <p class="text-slate-500 text-sm">Fill in the details below to create your event.</p>
</section>

<div id="create-event-form-wrapper">
  <% if (typeof pageError !== 'undefined' && pageError) { %>
    <%- include("../partials/error", { message: pageError }) %>
  <% } %>

  <section class="p-6 md:p-8 border border-slate-200 rounded-2xl bg-white shadow-lg">
    <form
      class="grid gap-6"
      hx-post="/events"
      hx-target="#create-event-form-wrapper"
      hx-swap="innerHTML"
      hx-push-url="false"
    >

      <%# Name %>
      <div class="grid gap-1.5">
        <label for="name" class="text-sm font-semibold text-slate-700">
          Event Name <span class="text-red-500">*</span>
        </label>
        <input
          id="name"
          name="name"
          type="text"
          required
          placeholder="e.g. Spring Hackathon 2026"
          value="<%= typeof formValues !== 'undefined' ? formValues.name : '' %>"
          class="w-full px-3.5 py-2.5 border border-slate-300 rounded-xl bg-white text-slate-900 placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500/30 focus:border-blue-500 transition"
        />
      </div>

      <%# Description with Alpine.js character counter %>
      <div
        class="grid gap-1.5"
        x-data="{ count: <%= typeof formValues !== 'undefined' && formValues.description ? formValues.description.length : 0 %>, max: 500 }"
      >
        <div class="flex items-baseline justify-between gap-2">
          <label for="description" class="text-sm font-semibold text-slate-700">Description</label>
          <span
            class="text-xs tabular-nums"
            :class="count > max ? 'text-red-500 font-semibold' : count >= max * 0.9 ? 'text-amber-500' : 'text-slate-400'"
          >
            <span x-text="count"></span> / <span x-text="max"></span>
          </span>
        </div>
        <textarea
          id="description"
          name="description"
          rows="4"
          maxlength="500"
          placeholder="Describe your event — what to expect, who should come, what to bring…"
          x-on:input="count = $event.target.value.length"
          class="w-full px-3.5 py-2.5 border border-slate-300 rounded-xl bg-white text-slate-900 placeholder:text-slate-400 resize-y focus:outline-none focus:ring-2 focus:ring-blue-500/30 focus:border-blue-500 transition"
        ><%= typeof formValues !== 'undefined' ? formValues.description : '' %></textarea>
        <p class="text-xs text-slate-400">Maximum 500 characters.</p>
      </div>

      <%# Location %>
      <div class="grid gap-1.5">
        <label for="location" class="text-sm font-semibold text-slate-700">Location</label>
        <input
          id="location"
          name="location"
          type="text"
          placeholder="e.g. Room 101, Building A"
          value="<%= typeof formValues !== 'undefined' ? formValues.location : '' %>"
          class="w-full px-3.5 py-2.5 border border-slate-300 rounded-xl bg-white text-slate-900 placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500/30 focus:border-blue-500 transition"
        />
      </div>

      <%# Category %>
      <div class="grid gap-1.5">
        <label for="category" class="text-sm font-semibold text-slate-700">
          Category <span class="text-slate-400 font-normal">(optional)</span>
        </label>
        <input
          id="category"
          name="category"
          type="text"
          placeholder="e.g. Workshop, Social, Tech Talk"
          value="<%= typeof formValues !== 'undefined' && formValues.category ? formValues.category : '' %>"
          class="w-full px-3.5 py-2.5 border border-slate-300 rounded-xl bg-white text-slate-900 placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500/30 focus:border-blue-500 transition"
        />
      </div>

      <%# Date & Time row — stacks on mobile, side-by-side on md+ %>
      <div class="grid gap-6 md:grid-cols-2">
        <div class="grid gap-1.5">
          <label for="startDatetime" class="text-sm font-semibold text-slate-700">
            Start Date &amp; Time <span class="text-red-500">*</span>
          </label>
          <input
            id="startDatetime"
            name="startDatetime"
            type="datetime-local"
            required
            value="<%= typeof formValues !== 'undefined' ? formValues.startDatetime : '' %>"
            class="w-full px-3.5 py-2.5 border border-slate-300 rounded-xl bg-white text-slate-900 focus:outline-none focus:ring-2 focus:ring-blue-500/30 focus:border-blue-500 transition"
          />
        </div>

        <div class="grid gap-1.5">
          <label for="endDatetime" class="text-sm font-semibold text-slate-700">
            End Date &amp; Time <span class="text-red-500">*</span>
          </label>
          <input
            id="endDatetime"
            name="endDatetime"
            type="datetime-local"
            required
            value="<%= typeof formValues !== 'undefined' ? formValues.endDatetime : '' %>"
            class="w-full px-3.5 py-2.5 border border-slate-300 rounded-xl bg-white text-slate-900 focus:outline-none focus:ring-2 focus:ring-blue-500/30 focus:border-blue-500 transition"
          />
        </div>
      </div>

      <%# Capacity & Status row — stacks on mobile, side-by-side on md+ %>
      <div class="grid gap-6 md:grid-cols-2">
        <div class="grid gap-1.5">
          <label for="capacity" class="text-sm font-semibold text-slate-700">
            Capacity <span class="text-slate-400 font-normal">(optional)</span>
          </label>
          <input
            id="capacity"
            name="capacity"
            type="number"
            min="1"
            placeholder="e.g. 50"
            value="<%= typeof formValues !== 'undefined' && formValues.capacity !== null ? formValues.capacity : '' %>"
            class="w-full px-3.5 py-2.5 border border-slate-300 rounded-xl bg-white text-slate-900 placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500/30 focus:border-blue-500 transition"
          />
        </div>

        <div class="grid gap-1.5">
          <label for="status" class="text-sm font-semibold text-slate-700">Status</label>
          <select
            id="status"
            name="status"
            class="w-full px-3.5 py-2.5 border border-slate-300 rounded-xl bg-white text-slate-900 focus:outline-none focus:ring-2 focus:ring-blue-500/30 focus:border-blue-500 transition appearance-none cursor-pointer"
          >
            <option value="DRAFT" <%= (typeof formValues === 'undefined' || formValues.status === 'DRAFT') ? 'selected' : '' %>>Draft</option>
            <option value="PUBLISHED" <%= (typeof formValues !== 'undefined' && formValues.status === 'PUBLISHED') ? 'selected' : '' %>>Published</option>
          </select>
        </div>
      </div>

      <%# Divider %>
      <hr class="border-slate-100" />

      <%# Actions %>
      <div class="flex items-center justify-between gap-3 flex-wrap">
        <a
          href="/events"
          class="px-4 py-2.5 rounded-xl border border-slate-200 bg-white text-slate-700 font-medium text-sm hover:bg-slate-50 transition no-underline"
        >
          Cancel
        </a>
        <button
          type="submit"
          class="px-6 py-2.5 rounded-xl bg-blue-600 text-white font-semibold text-sm cursor-pointer hover:bg-blue-700 active:bg-blue-800 transition shadow-sm"
        >
          Create Event
        </button>
      </div>

    </form>
  </section>
</div>
