<%
// Partial for the search results list.
//
// Used both inside the full search page (src/views/events/search.ejs) and as
// the HTMX swap target when the search input triggers an inline update. The
// wrapper <section id="search-results"> is what HTMX replaces; the wrapper
// must be present so outerHTML swaps keep working after the first swap.
//
// Expected locals:
//   events  — IEvent[] that matched the query (or all published upcoming
//             events if the query was empty)
//   query   — the raw, untrimmed query the user typed (for echoing in the
//             result-count line and the empty-state message)
//   session — the authenticated browser session
const trimmedQuery = (query ?? "").trim();

function formatDatetime(d) {
  return new Date(d).toLocaleString('en-US', {
    weekday: 'short',
    month: 'short',
    day: 'numeric',
    year: 'numeric',
    hour: 'numeric',
    minute: '2-digit',
  });
}
%>

<section id="search-results" class="grid gap-4">
  <% if (!events || events.length === 0) { %>
    <div class="p-6 border-2 border-pink-100 rounded-2xl bg-white shadow-md">
      <% if (trimmedQuery === "") { %>
        <p class="text-pink-400 mb-0">There are no upcoming published events right now.</p>
      <% } else { %>
        <p class="text-pink-400 mb-0">
          No events match &ldquo;<%= trimmedQuery %>&rdquo;.
        </p>
      <% } %>
    </div>
  <% } else { %>
    <% if (trimmedQuery !== "") { %>
      <p class="text-sm text-pink-500 font-semibold mb-0">
        Showing <%= events.length %> result<%= events.length === 1 ? "" : "s" %> for
        &ldquo;<%= trimmedQuery %>&rdquo;.
      </p>
    <% } %>

    <% events.forEach((event) => { %>
      <article class="rounded-2xl border-2 border-pink-100 bg-white shadow-md overflow-hidden">
        <div class="h-2 bg-gradient-to-r from-pink-300 via-pink-500 to-pink-300"></div>

        <div class="p-6 flex items-start justify-between gap-4 flex-wrap">
          <div class="flex-1 min-w-0">
            <h3 class="text-xl font-extrabold text-slate-900 mb-1">
              <a
                href="/events/<%= event.id %>"
                class="no-underline text-slate-900 hover:text-pink-600 transition"
              >
                <%= event.title %>
              </a>
            </h3>

            <div class="flex flex-wrap gap-x-4 gap-y-1 text-sm text-slate-500 mb-3">
              <span><%= event.location %></span>
              <span><%= formatDatetime(event.startDatetime) %></span>
              <% if (event.category) { %>
                <span>Category: <%= event.category %></span>
              <% } %>
            </div>

            <p class="text-slate-700 mb-0 leading-relaxed"><%= event.description %></p>
          </div>

          <div class="mt-2 flex flex-col gap-2 shrink-0">
            <a
              href="/events/<%= event.id %>"
              class="inline-block px-4 py-2.5 rounded-xl bg-white text-pink-500 border-2 border-pink-200 font-bold hover:bg-pink-50 no-underline text-sm transition text-center"
            >
              View details
            </a>

            <span class="inline-block px-3 py-1 rounded-full text-sm font-bold bg-green-100 text-green-800 text-center border border-green-200">
              <%= event.status %>
            </span>
          </div>
        </div>
      </article>
    <% }) %>
  <% } %>
</section>