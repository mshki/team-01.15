<%
  const isAdmin = session.authenticatedUser?.role === 'admin';
  const isOrganizer = event.organizerId === session.authenticatedUser?.userId;
  const canEdit = (isAdmin || isOrganizer) && event.status !== 'CANCELLED' && event.status !== 'CONCLUDED';

  const statusLabels = {
    PUBLISHED: 'Published',
    DRAFT: 'Draft',
    CANCELLED: 'Cancelled',
    CONCLUDED: 'Concluded',
  };

  const statusColors = {
    PUBLISHED: 'bg-green-100 text-green-800',
    DRAFT: 'bg-yellow-100 text-yellow-800',
    CANCELLED: 'bg-red-100 text-red-800',
    CONCLUDED: 'bg-slate-100 text-slate-600',
  };
%>

<div id="lifecycle-region" class="flex flex-col gap-4">
  <% if (typeof pageError !== 'undefined' && pageError) { %>
    <%- include("../../partials/error", { message: pageError }) %>
  <% } %>

  <div id="status-badge-region" class="flex items-center gap-2 flex-wrap">
    <span class="inline-block px-3 py-1 rounded-full text-sm font-medium <%= statusColors[event.status] %>">
      <%= statusLabels[event.status] %>
    </span>
  </div>

  <% if (isAdmin || isOrganizer) { %>
    <section class="p-6 border border-slate-200 rounded-2xl bg-white shadow-lg">
      <h2 class="text-lg font-semibold text-slate-900 mb-4">Manage event</h2>

      <% if (canEdit) { %>
        <div class="flex flex-wrap gap-3">
          <a
            href="/events/<%= event.id %>/edit"
            class="px-4 py-2.5 rounded-lg bg-blue-600 text-white font-medium hover:bg-blue-700 no-underline text-sm"
          >
            Edit event
          </a>

          <% if (event.status === 'DRAFT') { %>
            <form
              method="post"
              action="/events/<%= event.id %>/publish"
              hx-post="/events/<%= event.id %>/publish"
              hx-target="#lifecycle-region"
              hx-swap="outerHTML"
            >
              <button
                type="submit"
                class="px-4 py-2.5 rounded-lg bg-green-600 text-white font-medium hover:bg-green-700 cursor-pointer text-sm"
              >
                Publish event
              </button>
            </form>
          <% } %>

          <% if (event.status === 'PUBLISHED') { %>
            <form
              method="post"
              action="/events/<%= event.id %>/cancel"
              hx-post="/events/<%= event.id %>/cancel"
              hx-target="#lifecycle-region"
              hx-swap="outerHTML"
            >
              <button
                type="submit"
                class="px-4 py-2.5 rounded-lg bg-white text-red-700 border border-red-300 font-medium hover:bg-red-50 cursor-pointer text-sm"
                onclick="return confirm('Cancel this event? This cannot be undone.')"
              >
                Cancel event
              </button>
            </form>
          <% } %>
        </div>
      <% } else { %>
        <p class="text-sm text-slate-500">
          This event can no longer be edited because it has been cancelled or concluded.
        </p>
      <% } %>
    </section>
  <% } %>
</div>