<%
  const isAdmin = session.authenticatedUser?.role === 'admin';
  const isOrganizer = event.organizerId === session.authenticatedUser?.userId;
  const canEdit = (isAdmin || isOrganizer) && event.status !== 'CANCELLED' && event.status !== 'CONCLUDED';

  const statusLabels = {
    PUBLISHED: 'Published',
    DRAFT: 'Draft',
    CANCELLED: 'Cancelled',
    CONCLUDED: 'Concluded',
  };

  const statusColors = {
    PUBLISHED: 'bg-amber-100 text-amber-800 border-amber-200',
    DRAFT: 'bg-yellow-100 text-yellow-800 border-yellow-200',
    CANCELLED: 'bg-red-100 text-red-700 border-red-200',
    CONCLUDED: 'bg-stone-100 text-stone-600 border-stone-200',
  };
%>

<div id="lifecycle-region" class="flex flex-col gap-4">
  <% if (typeof pageError !== 'undefined' && pageError) { %>
    <%- include("../../partials/error", { message: pageError }) %>
  <% } %>

  <div
    id="status-badge-region"
    class="flex items-center gap-2 flex-wrap"
    x-data="{ pulse: false }"
    x-init="
      document.body.addEventListener('htmx:afterSwap', (e) => {
        if ($el.contains(e.target) || e.target.id === 'lifecycle-region') {
          pulse = true;
          setTimeout(() => pulse = false, 450);
        }
      })
    "
  >
    <span
      class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold border transition-transform duration-300 <%= statusColors[event.status] %>"
      :class="pulse ? 'scale-105 ring-2 ring-amber-300' : ''"
    >
      <%= statusLabels[event.status] %>
    </span>
  </div>

  <% if (isAdmin || isOrganizer) { %>
    <section class="p-6 border-2 border-amber-100 rounded-2xl bg-white shadow-md overflow-hidden">
      <div class="h-1.5 -mx-6 -mt-6 mb-4 bg-gradient-to-r from-amber-300 via-yellow-400 to-amber-300"></div>
      <h2 class="text-lg font-extrabold text-amber-900 mb-4">Manage Event</h2>

      <% if (canEdit) { %>
        <div class="flex flex-wrap gap-3">
          <a
            href="/events/<%= event.id %>/edit"
            class="px-4 py-2.5 rounded-xl bg-amber-100 text-amber-900 font-bold hover:bg-amber-200 no-underline text-sm transition"
          >
            Edit event
          </a>

          <% if (event.status === 'DRAFT') { %>
            <form
              method="post"
              action="/events/<%= event.id %>/publish"
              hx-post="/events/<%= event.id %>/publish"
              hx-target="#lifecycle-region"
              hx-swap="outerHTML"
            >
              <button
                type="submit"
                class="px-4 py-2.5 rounded-xl bg-amber-800 text-yellow-50 font-bold hover:bg-amber-900 cursor-pointer text-sm transition shadow-sm"
              >
                Publish event
              </button>
            </form>
          <% } %>

          <% if (event.status === 'PUBLISHED') { %>
            <form
              method="post"
              action="/events/<%= event.id %>/cancel"
              hx-post="/events/<%= event.id %>/cancel"
              hx-target="#lifecycle-region"
              hx-swap="outerHTML"
            >
              <button
                type="submit"
                class="px-4 py-2.5 rounded-xl bg-white text-red-600 border-2 border-red-200 font-bold hover:bg-red-50 cursor-pointer text-sm transition"
                onclick="return confirm('Cancel this event? This cannot be undone.')"
              >
                Cancel event
              </button>
            </form>
          <% } %>
        </div>
      <% } else { %>
        <p class="text-sm text-amber-700">
          This event can no longer be edited because it has been cancelled or concluded.
        </p>
      <% } %>
    </section>
  <% } %>
</div>
