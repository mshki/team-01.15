<%
const goingCount = event.attendees.filter(a => a.rsvpStatus === 'GOING').length;
const waitlistedCount = event.attendees.filter(a => a.rsvpStatus === 'WAITLISTED').length;

const isAdmin = session.authenticatedUser?.role === 'admin';
const isOrganizer = event.organizerId === session.authenticatedUser?.userId;

const canEdit = (isAdmin || isOrganizer) && event.status !== 'CANCELLED' && event.status !== 'CONCLUDED';
const canRsvp = !isAdmin && !isOrganizer && event.status === 'PUBLISHED';
%>

<article class="p-6 border border-slate-200 rounded-2xl bg-white shadow-lg">
  <div class="flex items-start justify-between gap-4 flex-wrap">
    <div>
      <h3 class="text-xl font-semibold text-slate-900 mb-1">
        <a
          href="/events/<%= event.id %>"
          class="no-underline text-slate-900 hover:text-blue-700"
        >
          <%= event.title %>
        </a>
      </h3>

      <p class="text-slate-500 text-sm mb-2"><%= event.location %></p>

      <% if (event.category) { %>
        <p class="text-sm text-slate-500 mb-2">Category: <%= event.category %></p>
      <% } %>

      <p class="text-slate-700 mb-0"><%= event.description %></p>
    </div>

    <div class="mt-4 flex flex-col gap-2">
      <% if ((isAdmin || isOrganizer) && canEdit) { %>
        <a
          href="/events/<%= event.id %>/edit"
          class="inline-block px-4 py-2.5 rounded-lg bg-blue-600 text-white font-medium hover:bg-blue-700 no-underline text-sm"
        >
          Edit event
        </a>
      <% } %>

      <% if ((isAdmin || isOrganizer) && event.status === "PUBLISHED") { %>
        <form
          method="post"
          action="/events/<%= event.id %>/cancel"
          hx-post="/events/<%= event.id %>/cancel"
          hx-target="closest article"
          hx-swap="delete"
        >
          <button
            type="submit"
            class="inline-block px-4 py-2.5 rounded-lg bg-white text-red-700 border border-red-300 font-medium hover:bg-red-50 cursor-pointer text-sm"
            onclick="return confirm('Cancel this event? This cannot be undone.')"
          >
            Cancel Event
          </button>
        </form>
      <% } %>

      <a
        href="/events/<%= event.id %>"
        class="inline-block px-4 py-2.5 rounded-lg bg-white text-slate-700 border border-slate-300 font-medium hover:bg-slate-50 no-underline text-sm"
      >
        View details
      </a>
    </div>

    <div class="mt-5 grid gap-4 md:grid-cols-2">
      <% if (canRsvp) { %>
        <%- include("./rsvp-panel", {
          event,
          session,
          idSuffix: event.id,
          oob: false
        }) %>
      <% } %>

      <%- include("./attendance-panel", {
        event,
        idSuffix: event.id,
        oob: false
      }) %>
    </div>

    <span class="inline-block px-3 py-1 rounded-full text-sm font-medium bg-green-100 text-green-800">
      <%= event.status %>
    </span>
  </div>
</article>