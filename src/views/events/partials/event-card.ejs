<%
const goingCount = event.attendees.filter(a => a.rsvpStatus === 'GOING').length;
const waitlistedCount = event.attendees.filter(a => a.rsvpStatus === 'WAITLISTED').length;

const isAdmin = session.authenticatedUser?.role === 'admin';
const isOrganizer = event.organizerId === session.authenticatedUser?.userId;

const canEdit = (isAdmin || isOrganizer) && event.status !== 'CANCELLED' && event.status !== 'CONCLUDED';
const canRsvp = !isAdmin && !isOrganizer && event.status === 'PUBLISHED';

const statusColors = {
  PUBLISHED: 'bg-pink-100 text-pink-800 border-pink-200',
  DRAFT: 'bg-yellow-100 text-yellow-800 border-yellow-200',
  CANCELLED: 'bg-red-100 text-red-700 border-red-200',
  CONCLUDED: 'bg-slate-100 text-slate-600 border-slate-200',
};
%>

<article class="rounded-2xl border-2 border-pink-100 bg-white shadow-md overflow-hidden font-[Nunito,sans-serif]">
  <%# Pink top stripe %>
  <div class="h-1.5 bg-gradient-to-r from-pink-300 via-pink-400 to-pink-300"></div>

  <div class="p-6">
    <%# Title row %>
    <div class="flex items-start justify-between gap-4 flex-wrap mb-3">
      <div class="flex-1 min-w-0">
        <h3 class="text-xl font-extrabold text-pink-900 mb-1">
          <a href="/events/<%= event.id %>" class="no-underline text-pink-900 hover:text-pink-600 transition">
            <%= event.title %>
          </a>
        </h3>

        <div class="flex flex-wrap gap-x-4 gap-y-0.5 text-sm text-pink-500 mb-2">
          <span class="flex items-center gap-1">
            <svg class="w-3.5 h-3.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/>
              <circle cx="12" cy="9" r="2.5"/>
            </svg>
            <%= event.location %>
          </span>
          <% if (event.category) { %>
            <span class="flex items-center gap-1">
              <svg class="w-3.5 h-3.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path d="M4 6h16M4 10h16M4 14h8"/>
              </svg>
              <%= event.category %>
            </span>
          <% } %>
        </div>

        <p class="text-slate-600 text-sm leading-relaxed line-clamp-2"><%= event.description %></p>
      </div>

      <%# Status badge + action buttons %>
      <div class="flex flex-col gap-2 shrink-0 items-end">
        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold border <%= statusColors[event.status] %>">
          <%= event.status %>
        </span>

        <% if ((isAdmin || isOrganizer) && canEdit) { %>
          <a
            href="/events/<%= event.id %>/edit"
            class="px-3.5 py-2 rounded-xl bg-pink-100 text-pink-800 font-bold hover:bg-pink-200 no-underline text-xs transition"
          >
            Edit
          </a>
        <% } %>

        <% if ((isAdmin || isOrganizer) && event.status === "PUBLISHED") { %>
          <form
            method="post"
            action="/events/<%= event.id %>/cancel"
            hx-post="/events/<%= event.id %>/cancel"
            hx-target="closest article"
            hx-swap="delete"
          >
            <button
              type="submit"
              class="px-3.5 py-2 rounded-xl bg-white text-red-600 border-2 border-red-200 font-bold hover:bg-red-50 cursor-pointer text-xs transition"
              onclick="return confirm('Cancel this event? This cannot be undone.')"
            >
              Cancel
            </button>
          </form>
        <% } %>

        <a
          href="/events/<%= event.id %>"
          class="px-3.5 py-2 rounded-xl bg-pink-500 text-white font-bold hover:bg-pink-600 no-underline text-xs transition shadow-sm"
        >
          View details
        </a>
      </div>
    </div>

    <%# RSVP + attendance panels %>
    <% if (canRsvp || true) { %>
      <div class="mt-4 pt-4 border-t-2 border-pink-50 grid gap-3 md:grid-cols-2">
        <% if (canRsvp) { %>
          <%- include("./rsvp-panel", {
            event,
            session,
            idSuffix: event.id,
            oob: false
          }) %>
        <% } %>

        <%- include("./attendance-panel", {
          event,
          idSuffix: event.id,
          oob: false
        }) %>
      </div>
    <% } %>
  </div>
</article>
