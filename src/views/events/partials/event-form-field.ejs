<%
  const isEdit = typeof isEditMode !== 'undefined' && isEditMode;
  
  const form = (typeof values !== 'undefined' && values) ? values : 
  (typeof formValues !== 'undefined' && formValues) ? formValues :
  (typeof event !== 'undefined' ? event : {});

  function toDatetimeLocal(value) {
    if (!value) return '';
    const d = new Date(value);
    if (isNaN(d.getTime())) return value;
    const pad = (n) => String(n).padStart(2, '0');
    return `${d.getFullYear()}-${pad(d.getMonth()+1)}-${pad(d.getDate())}T${pad(d.getHours())}:${pad(d.getMinutes())}`;
  }

  const titleValue = form.name ?? form.title ?? '';
  const descriptionValue = form.description ?? '';
  const locationValue = form.location ?? '';
  const categoryValue = form.category ?? '';
  const capacityValue = form.capacity ?? '';
  const startValue = toDatetimeLocal(form.startDatetime);
  const endValue = toDatetimeLocal(form.endDatetime);
  const statusValue = form.status ?? 'DRAFT';

  const inputClass = isEdit
    ? 'w-full px-3.5 py-2.5 border border-sky-200 rounded-xl bg-sky-50 text-slate-800 placeholder:text-sky-400 focus:outline-none focus:ring-2 focus:ring-sky-300 focus:border-sky-400 focus:bg-white transition'
    : 'w-full px-3.5 py-2.5 border-2 border-lime-200 rounded-xl bg-lime-50 text-slate-800 placeholder:text-green-600 focus:outline-none focus:ring-2 focus:ring-lime-300 focus:border-lime-400 focus:bg-white transition';

  const labelClass = isEdit
    ? 'text-sm font-semibold text-sky-700'
    : 'text-sm font-bold text-green-900';

  const sectionClass = isEdit
    ? 'p-6 md:p-8 border border-sky-100 rounded-2xl bg-gradient-to-br from-white to-sky-50 shadow-lg'
    : 'p-6 md:p-8 border-2 border-lime-100 rounded-2xl bg-white shadow-md';

  const buttonClass = isEdit
    ? 'px-6 py-2.5 rounded-xl bg-sky-500 text-white font-semibold text-sm hover:bg-sky-600 transition shadow-sm'
    : 'px-6 py-2.5 rounded-xl bg-green-600 text-white font-extrabold text-sm hover:bg-green-700 transition shadow-sm';

  const cancelClass = isEdit
    ? 'px-4 py-2.5 rounded-xl border border-sky-200 text-sky-700 font-medium text-sm hover:bg-sky-50 transition no-underline'
    : 'px-4 py-2.5 rounded-xl border-2 border-lime-200 bg-white text-green-900 font-bold text-sm hover:bg-lime-50 transition no-underline';
%>

<div
  id="event-form-container"
  hx-ext="response-targets"
  x-data="{ isDirty: false, descCount: <%= descriptionValue.length %>, maxDesc: 500 }"
  @beforeunload.window="if (isDirty) { $event.preventDefault(); $event.returnValue = ''; }"
>

  <% if (typeof pageError !== 'undefined' && pageError) { %>
    <%- include("../../partials/error", { message: pageError }) %>
  <% } %>

  <section class="<%= sectionClass %>">
    <div class="flex items-start justify-between gap-4">
      
      <form
        class="grid gap-6 flex-1"
        hx-post="<%= isEdit ? `/events/${event.id}/edit` : '/events' %>"
        hx-target="#event-form-container"
        hx-target-400="#event-form-container"
        hx-swap="outerHTML"
        @input="isDirty = true"
        @change="isDirty = true"
        @submit="isDirty = false"
      >

        <%# Title %>
        <div class="grid gap-1.5">
          <label for="name" class="<%= labelClass %>">
            Event Name <span class="text-red-400">*</span>
          </label>
          <input id="name" name="name" type="text" required
            value="<%= titleValue %>"
            placeholder="e.g. Spring Hackathon 2026"
            class="<%= inputClass %>" />
        </div>

        <%# Description %>
        <div class="grid gap-1.5">
          <div class="flex items-baseline justify-between">
            <label class="<%= labelClass %>">Description</label>
            <span class="text-xs"
              :class="descCount > maxDesc ? 'text-red-500' : '<%= isEdit ? 'text-sky-400' : 'text-green-900' %>'">
              <span x-text="descCount"></span>/<span x-text="maxDesc"></span>
            </span>
          </div>
          <textarea name="description" rows="4" maxlength="500"
            x-on:input="descCount = $event.target.value.length"
            class="<%= inputClass %>"><%= descriptionValue %></textarea>
        </div>

        <%# Location + Category %>
        <div class="grid gap-6 md:grid-cols-2">
          <input name="location" value="<%= locationValue %>" placeholder="Location"
            class="<%= inputClass %>" />
          <input name="category" value="<%= categoryValue %>" placeholder="Category"
            class="<%= inputClass %>" />
        </div>

        <%# Dates %>
        <div class="grid gap-6 md:grid-cols-2">
          <input type="datetime-local" name="startDatetime" required value="<%= startValue %>"
            class="<%= inputClass %>" />
          <input type="datetime-local" name="endDatetime" required value="<%= endValue %>"
            class="<%= inputClass %>" />
        </div>

        <%# Capacity + Status %>
        <div class="grid gap-6 md:grid-cols-2">
          <input type="number" name="capacity" value="<%= capacityValue %>"
            class="<%= inputClass %>" />

          <select name="status" class="<%= inputClass %>">
            <% (isEdit 
                ? ['DRAFT','PUBLISHED','CANCELLED','CONCLUDED']
                : ['DRAFT','PUBLISHED']
              ).forEach(s => { %>
              <option value="<%= s %>" <%= statusValue === s ? 'selected' : '' %>>
                <%= s %>
              </option>
            <% }) %>
          </select>
        </div>

        <hr class="<%= isEdit ? 'border-sky-100' : 'border-lime-100' %>" />

        <%# Actions %>
        <div class="flex justify-between">
          <a href="<%= isEdit ? `/events/${event.id}` : '/events' %>"
            @click="if (isEdit && isDirty && !confirm('Discard changes?')) $event.preventDefault()"
            class="<%= cancelClass %>">
            Cancel
          </a>

          <button type="submit" class="<%= buttonClass %>">
            <%= isEdit ? 'Save Changes ☁️🐶' : 'Create Event 🐸' %>
          </button>
        </div>

      </form>

      <%# Character image %>
      <img 
        src="<%= isEdit ? '/cinnamonroll1.png' : '/keropi1.png' %>"
        class="w-24 md:w-32 hidden md:block self-end drop-shadow-md"
      />
    </div>
  </section>
</div>