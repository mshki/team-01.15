<%
  const form = (typeof values !== 'undefined' && values) ? values : event;

  function toDatetimeLocal(value) {
    if (!value) return '';
    const d = new Date(value);
    const pad = (n) => String(n).padStart(2, '0');
    return `${d.getFullYear()}-${pad(d.getMonth()+1)}-${pad(d.getDate())}T${pad(d.getHours())}:${pad(d.getMinutes())}`;
  }

  const titleValue = form.title ?? form.name ?? '';
  const descriptionValue = form.description ?? '';
  const locationValue = form.location ?? '';
  const capacityValue = form.capacity ?? '';
  const startValue = toDatetimeLocal(form.startDatetime);
  const endValue = toDatetimeLocal(form.endDatetime);
  const category = form.category ?? '';
  const status = form.status ?? '';
  const pageMessage = typeof pageError !== 'undefined' ? pageError : '';

  const eventStatuses = ['DRAFT', 'PUBLISHED', 'CANCELLED', 'CONCLUDED'];
  const statusLabels = {
    PUBLISHED: 'Published',
    DRAFT: 'Draft',
    CANCELLED: 'Cancelled',
    CONCLUDED: 'Concluded',
  };

  const statusColors = {
    PUBLISHED: 'bg-green-100 text-green-800',
    DRAFT: 'bg-yellow-100 text-yellow-800',
    CANCELLED: 'bg-red-100 text-red-800',
    CONCLUDED: 'bg-slate-100 text-slate-600',
  };

%>

<div id="edit-event-shell">
  <section class="mb-5 p-6 border border-slate-200 rounded-2xl bg-gradient-to-b from-white to-slate-50 shadow-lg">
    <h1 class="text-3xl font-bold text-slate-900 mb-3">Edit Event</h1>
    <p class="text-slate-600">Update the details for <strong><%= event.title %></strong>.</p>
  </section>

  <% if (pageMessage) { %>
    <%- include("../../partials/error", { message: pageMessage }) %>
  <% } %>

  <section class="max-w-3xl p-6 border border-slate-200 rounded-2xl bg-white shadow-lg">
    <form
      class="grid gap-4"
      method="post"
      action="/events/<%= event.id %>/edit"
      hx-post="/events/<%= event.id %>/edit"
      hx-target="#edit-event-shell"
      hx-swap="outerHTML"
    >
      <div>
        <label for="name" class="block text-sm font-medium mb-1">Title</label>
        <input
          id="name"
          name="name"
          type="text"
          value="<%= titleValue %>"
          class="w-full px-3 py-2.5 border border-slate-300 rounded-xl bg-white focus:outline-2 focus:outline-blue-500/20 focus:border-blue-500"
        />
      </div>

      <div>
        <label for="description" class="block text-sm font-medium mb-1">Description</label>
        <textarea
          id="description"
          name="description"
          rows="4"
          class="w-full px-3 py-2.5 border border-slate-300 rounded-xl bg-white focus:outline-2 focus:outline-blue-500/20 focus:border-blue-500"
        ><%= descriptionValue %></textarea>
      </div>

      <div>
        <label for="location" class="block text-sm font-medium mb-1">Location</label>
        <input
          id="location"
          name="location"
          type="text"
          value="<%= locationValue %>"
          class="w-full px-3 py-2.5 border border-slate-300 rounded-xl bg-white focus:outline-2 focus:outline-blue-500/20 focus:border-blue-500"
        />
      </div>

      <div>
        <label for="category" class="block text-sm font-medium mb-1">
          Category <span class="text-slate-400 font-normal">(optional)</span>
        </label>
        <input
          id="category"
          name="category"
          type="text"
          value="<%= category %>"
          class="w-full px-3 py-2.5 border border-slate-300 rounded-xl bg-white focus:outline-2 focus:outline-blue-500/20 focus:border-blue-500"
        />
      </div>

      <div>
        <label for="startDatetime" class="block text-sm font-medium mb-1">Start Date &amp; Time</label>
        <input
          id="startDatetime"
          name="startDatetime"
          type="datetime-local"
          value="<%= startValue %>"
          class="w-full px-3 py-2.5 border border-slate-300 rounded-xl bg-white focus:outline-2 focus:outline-blue-500/20 focus:border-blue-500"
        />
      </div>

      <div>
        <label for="endDatetime" class="block text-sm font-medium mb-1">End Date &amp; Time</label>
        <input
          id="endDatetime"
          name="endDatetime"
          type="datetime-local"
          value="<%= endValue %>"
          class="w-full px-3 py-2.5 border border-slate-300 rounded-xl bg-white focus:outline-2 focus:outline-blue-500/20 focus:border-blue-500"
        />
      </div>

      <div>
        <label for="capacity" class="block text-sm font-medium mb-1">
          Capacity <span class="text-slate-400 font-normal">(optional)</span>
        </label>
        <input
          id="capacity"
          name="capacity"
          type="number"
          min="1"
          value="<%= capacityValue %>"
          class="w-full px-3 py-2.5 border border-slate-300 rounded-xl bg-white focus:outline-2 focus:outline-blue-500/20 focus:border-blue-500"
        />
      </div>

      <div>
        <label for="status" class="block text-sm font-medium mb-1">Status</label>
        <select
          id="status"
          name="status"
          class="w-full px-3 py-2.5 border border-slate-300 rounded-xl bg-white focus:outline-2 focus:outline-blue-500/20 focus:border-blue-500"
        >
          <% eventStatuses.forEach((s) => { %>
            <option value="<%= s %>" <%= status === s ? 'selected' : '' %>>
              <%= statusLabels[s] %>
            </option>
          <% }) %>
        </select>
      </div>
  

      <div class="flex items-center gap-3 pt-2">
        <button
          type="submit"
          class="px-4 py-2.5 rounded-lg bg-blue-600 text-white font-medium cursor-pointer hover:bg-blue-700"
        >
          Save Changes
        </button>

        <a
          href="/events/<%= event.id %>"
          class="px-4 py-2.5 rounded-lg bg-white text-slate-700 border border-slate-300 font-medium hover:bg-slate-50 no-underline"
        >
          Cancel
        </a>
      </div>
    </form>
  </section>
</div>