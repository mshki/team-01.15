<%
  const form = (typeof values !== 'undefined' && values) ? values : event;

  function toDatetimeLocal(value) {
    if (!value) return '';
    const d = new Date(value);
    const pad = (n) => String(n).padStart(2, '0');
    return `${d.getFullYear()}-${pad(d.getMonth()+1)}-${pad(d.getDate())}T${pad(d.getHours())}:${pad(d.getMinutes())}`;
  }

  const titleValue = form.title ?? form.name ?? '';
  const descriptionValue = form.description ?? '';
  const locationValue = form.location ?? '';
  const capacityValue = form.capacity ?? '';
  const startValue = toDatetimeLocal(form.startDatetime);
  const endValue = toDatetimeLocal(form.endDatetime);
  const category = form.category ?? '';
  const status = form.status ?? '';

  const eventStatuses = ['DRAFT', 'PUBLISHED', 'CANCELLED', 'CONCLUDED'];
  const statusLabels = {
    PUBLISHED: 'Published',
    DRAFT: 'Draft',
    CANCELLED: 'Cancelled',
    CONCLUDED: 'Concluded',
  };

  const inputClass =
    'w-full rounded-xl border border-slate-300 bg-white px-3 py-2.5 transition-colors duration-150 ' +
    'focus:border-blue-500 focus:outline-none focus:ring-4 focus:ring-blue-500/10';

  const primaryButtonClass =
    'inline-flex items-center justify-center rounded-xl bg-blue-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm ' +
    'transition-all duration-200 ease-out hover:bg-blue-700 focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-blue-500/30';

  const secondaryButtonClass =
    'inline-flex items-center justify-center rounded-xl border border-slate-300 bg-white px-4 py-2.5 text-sm font-semibold text-slate-700 ' +
    'transition-all duration-200 ease-out hover:bg-slate-50 focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-slate-200';
%>

<div
  id="edit-event-shell"
  hx-ext="response-targets"
  x-data="{ isDirty: false }"
  @beforeunload.window="if (isDirty) { $event.preventDefault(); $event.returnValue = ''; }"
>
  <section class="mb-5 rounded-2xl border border-slate-200 bg-gradient-to-b from-white to-slate-50 p-6 shadow-lg">
    <h1 class="mb-3 text-3xl font-bold text-slate-900">Edit Event</h1>
    <p class="text-slate-600">Update the details for <strong><%= event.title %></strong>.</p>
  </section>

  <% if (typeof pageError !== 'undefined' && pageError) { %>
    <%- include("../../partials/error", { message: pageError }) %>
  <% } %>

  <section class="max-w-3xl rounded-2xl border border-slate-200 bg-white p-6 shadow-lg">
    <form
      class="grid gap-4"
      method="post"
      hx-post="/events/<%= event.id %>/edit"
      hx-target="#edit-event-shell"
      hx-target-400="#edit-event-shell"
      hx-swap="outerHTML"
      @input="isDirty = true"
      @change="isDirty = true"
      @submit="isDirty = false"
    >
      <div>
        <label for="name" class="mb-1 block text-sm font-medium">Title</label>
        <input
          id="name"
          name="name"
          type="text"
          value="<%= titleValue %>"
          class="<%= inputClass %>"
        />
      </div>

      <div>
        <label for="description" class="mb-1 block text-sm font-medium">Description</label>
        <textarea
          id="description"
          name="description"
          rows="4"
          class="<%= inputClass %>"
        ><%= descriptionValue %></textarea>
      </div>

      <div>
        <label for="location" class="mb-1 block text-sm font-medium">Location</label>
        <input
          id="location"
          name="location"
          type="text"
          value="<%= locationValue %>"
          class="<%= inputClass %>"
        />
      </div>

      <div>
        <label for="category" class="mb-1 block text-sm font-medium">
          Category <span class="font-normal text-slate-400">(optional)</span>
        </label>
        <input
          id="category"
          name="category"
          type="text"
          value="<%= category %>"
          class="<%= inputClass %>"
        />
      </div>

      <div>
        <label for="startDatetime" class="mb-1 block text-sm font-medium">Start Date &amp; Time</label>
        <input
          id="startDatetime"
          name="startDatetime"
          type="datetime-local"
          value="<%= startValue %>"
          class="<%= inputClass %>"
        />
      </div>

      <div>
        <label for="endDatetime" class="mb-1 block text-sm font-medium">End Date &amp; Time</label>
        <input
          id="endDatetime"
          name="endDatetime"
          type="datetime-local"
          value="<%= endValue %>"
          class="<%= inputClass %>"
        />
      </div>

      <div>
        <label for="capacity" class="mb-1 block text-sm font-medium">
          Capacity <span class="font-normal text-slate-400">(optional)</span>
        </label>
        <input
          id="capacity"
          name="capacity"
          type="number"
          min="1"
          value="<%= capacityValue %>"
          class="<%= inputClass %>"
        />
      </div>

      <div>
        <label for="status" class="mb-1 block text-sm font-medium">Status</label>
        <select
          id="status"
          name="status"
          class="<%= inputClass %>"
        >
          <% eventStatuses.forEach((s) => { %>
            <option value="<%= s %>" <%= status === s ? 'selected' : '' %>>
              <%= statusLabels[s] %>
            </option>
          <% }) %>
        </select>
      </div>

      <div class="flex flex-col gap-3 pt-2 sm:flex-row">
        <button type="submit" class="<%= primaryButtonClass %>">
          Save Changes
        </button>

        <a
          href="/events/<%= event.id %>"
          @click="if (isDirty && !confirm('You have unsaved changes. Are you sure you want to discard them?')) $event.preventDefault()"
          class="<%= secondaryButtonClass %> no-underline"
        >
          Cancel
        </a>
      </div>
    </form>
  </section>
</div>