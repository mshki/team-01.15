<section class="mb-5 p-6 border border-slate-200 rounded-2xl bg-gradient-to-b from-white to-slate-50 shadow-lg">
  <h1 class="text-3xl font-bold text-slate-900 mb-3">Search Events</h1>
  <p class="text-slate-500">
    Search published upcoming events by title, description, location, or category.
    Leave the box empty to see all upcoming events.
  </p>
</section>

<% if (pageError) { %>
  <%- include("../partials/error", { message: pageError }) %>
<% } %>

<section class="mb-5 p-6 border border-slate-200 rounded-2xl bg-white shadow-lg">
  <form method="get" action="/events/search" class="grid gap-4 md:grid-cols-[1fr_auto_auto]">
    <div>
      <label for="q" class="block text-sm font-medium mb-1">Search</label>
      <input
        id="q"
        name="q"
        type="text"
        value="<%= query ?? "" %>"
        placeholder="e.g. jazz, library, community"
        hx-get="/events/search"
        hx-trigger="keyup changed delay:300ms"
        hx-target="#search-results"
        hx-swap="outerHTML"
        hx-replace-url="true"
        class="w-full px-3 py-2.5 border border-slate-300 rounded-xl bg-white"
      />
    </div>

    <div class="flex items-end">
      <button
        type="submit"
        class="px-4 py-2.5 rounded-lg bg-blue-600 text-white font-medium hover:bg-blue-700 cursor-pointer"
      >
        Search
      </button>
    </div>

    <div class="flex items-end">
      <a
        href="/events/search"
        class="px-4 py-2.5 rounded-lg bg-white text-slate-700 border border-slate-300 font-medium no-underline hover:bg-slate-50"
      >
        Clear
      </a>
    </div>
  </form>
</section>

<%- include("./partials/search-results", { events, query, session }) %>
