<section class="mb-5 p-6 border border-slate-200 rounded-2xl bg-gradient-to-b from-white to-slate-50 shadow-lg">
  <h1 class="text-3xl font-bold text-slate-900 mb-3">Search Events</h1>
  <p class="text-slate-500">
    Search published upcoming events by title, description, location, or category.
    Leave the box empty to see all upcoming events.
  </p>
</section>

<% if (pageError) { %>
  <%- include("../partials/error", { message: pageError }) %>
<% } %>

<section class="mb-5 p-6 border border-slate-200 rounded-2xl bg-white shadow-lg">
  <form method="get" action="/events/search" class="grid gap-4 md:grid-cols-[1fr_auto_auto]">
    <div>
      <label for="q" class="block text-sm font-medium mb-1">Search</label>
      <input
        id="q"
        name="q"
        type="text"
        value="<%= query ?? "" %>"
        placeholder="e.g. jazz, library, community"
        class="w-full px-3 py-2.5 border border-slate-300 rounded-xl bg-white"
      />
    </div>

    <div class="flex items-end">
      <button
        type="submit"
        class="px-4 py-2.5 rounded-lg bg-blue-600 text-white font-medium hover:bg-blue-700 cursor-pointer"
      >
        Search
      </button>
    </div>

    <div class="flex items-end">
      <a
        href="/events/search"
        class="px-4 py-2.5 rounded-lg bg-white text-slate-700 border border-slate-300 font-medium no-underline hover:bg-slate-50"
      >
        Clear
      </a>
    </div>
  </form>
</section>

<section class="grid gap-4">
  <% const trimmedQuery = (query ?? "").trim(); %>

  <% if (!events || events.length === 0) { %>
    <div class="p-6 border border-slate-200 rounded-2xl bg-white shadow-lg">
      <% if (trimmedQuery === "") { %>
        <p class="text-slate-500 mb-0">There are no upcoming published events right now.</p>
      <% } else { %>
        <p class="text-slate-500 mb-0">
          No events match &ldquo;<%= trimmedQuery %>&rdquo;.
        </p>
      <% } %>
    </div>
  <% } else { %>
    <% if (trimmedQuery !== "") { %>
      <p class="text-sm text-slate-500 mb-0">
        Showing <%= events.length %> result<%= events.length === 1 ? "" : "s" %> for
        &ldquo;<%= trimmedQuery %>&rdquo;.
      </p>
    <% } %>

    <% events.forEach((event) => { %>
      <%
      function formatDatetime(d) {
        return new Date(d).toLocaleString('en-US', {
          weekday: 'short',
          month: 'short',
          day: 'numeric',
          year: 'numeric',
          hour: 'numeric',
          minute: '2-digit',
        });
      }
      %>
      <article class="p-6 border border-slate-200 rounded-2xl bg-white shadow-lg">
        <div class="flex items-start justify-between gap-4 flex-wrap">
          <div class="flex-1 min-w-0">
            <h3 class="text-xl font-semibold text-slate-900 mb-1">
              <a
                href="/events/<%= event.id %>"
                class="no-underline text-slate-900 hover:text-blue-700"
              >
                <%= event.title %>
              </a>
            </h3>

            <p class="text-slate-500 text-sm mb-1"><%= event.location %></p>

            <p class="text-slate-500 text-sm mb-2">
              <%= formatDatetime(event.startDatetime) %>
            </p>

            <% if (event.category) { %>
              <p class="text-sm text-slate-500 mb-2">Category: <%= event.category %></p>
            <% } %>

            <p class="text-slate-700 mb-0"><%= event.description %></p>
          </div>

          <div class="mt-2 flex flex-col gap-2">
            <a
              href="/events/<%= event.id %>"
              class="inline-block px-4 py-2.5 rounded-lg bg-white text-slate-700 border border-slate-300 font-medium hover:bg-slate-50 no-underline text-sm"
            >
              View details
            </a>
            <span class="inline-block px-3 py-1 rounded-full text-sm font-medium bg-green-100 text-green-800 text-center">
              <%= event.status %>
            </span>
          </div>
        </div>
      </article>
    <% }) %>
  <% } %>
</section>
