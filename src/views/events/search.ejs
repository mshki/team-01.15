<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&display=swap" />

<div class="font-[Nunito,sans-serif] flex flex-col gap-5">

  <section class="p-6 border-2 border-pink-200 rounded-2xl bg-gradient-to-br from-pink-50 to-pink-100 shadow-lg overflow-hidden">
    <div class="flex items-end justify-between gap-4">
      <div>
        <h1 class="text-3xl font-extrabold text-pink-600 mb-1">Search Events 🎀</h1>
        <p class="text-pink-400 text-sm">
          Search published upcoming events by title, description, location, or category.
        </p>
      </div>
      <img
        src="/melody2.png"
        alt="My Melody"
        class="w-28 md:w-40 shrink-0 drop-shadow-md self-end hidden sm:block"
      />
    </div>
  </section>

  <% if (pageError) { %>
    <%- include("../partials/error", { message: pageError }) %>
  <% } %>

  <section class="p-6 border-2 border-pink-100 rounded-2xl bg-white shadow-md">
    <form
      method="get"
      action="/events/search"
      class="flex flex-col sm:flex-row gap-3"
      x-data="{ query: `<%= (query ?? '').replace(/`/g, '\\`') %>` }"
    >
      <label for="q" class="sr-only">Search events</label>

      <div class="relative flex-1">
        <svg
          class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-pink-300 pointer-events-none"
          fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"
        >
          <circle cx="11" cy="11" r="7"/>
          <path d="m21 21-4.3-4.3"/>
        </svg>

        <input
          id="q"
          name="q"
          type="text"
          value="<%= query ?? "" %>"
          x-model="query"
          placeholder="e.g. jazz, library, community"
          hx-get="/events/search"
          hx-trigger="keyup changed delay:300ms"
          hx-target="#search-results"
          hx-swap="outerHTML"
          hx-replace-url="true"
          class="w-full pl-12 pr-12 py-3.5 text-base border-2 border-pink-200 rounded-xl bg-pink-50 focus:outline-none focus:ring-2 focus:ring-pink-300 focus:border-pink-300 focus:bg-white placeholder:text-pink-300 text-slate-700 transition"
        />

        <button
          type="button"
          x-show="query.length > 0"
          x-cloak
          @click="query = ''; $nextTick(() => document.getElementById('q').focus())"
          aria-label="Clear search"
          class="absolute right-3 top-1/2 -translate-y-1/2 w-7 h-7 flex items-center justify-center rounded-full text-pink-300 hover:bg-pink-100 hover:text-pink-500 transition cursor-pointer"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M6 6l12 12M18 6L6 18"/>
          </svg>
        </button>
      </div>

      <button
        type="submit"
        class="px-6 py-3.5 rounded-xl bg-pink-500 text-white text-base font-bold hover:bg-pink-600 cursor-pointer transition shadow-sm"
      >
        Search
      </button>

      <a
        href="/events/search"
        class="px-6 py-3.5 rounded-xl bg-white text-pink-500 border-2 border-pink-200 font-bold no-underline hover:bg-pink-50 transition text-center"
      >
        Clear
      </a>
    </form>

    <p class="text-sm text-pink-400 mt-3 mb-0">
      Leave the box empty to see all upcoming events.
    </p>
  </section>

  <%- include("./partials/search-results", { events, query, session }) %>

</div>