<style>
  @import url('https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&display=swap');
  .sanrio-font { font-family: 'Nunito', sans-serif; }
</style>

<div class="sanrio-font min-h-[80vh] flex flex-col items-center justify-center relative">

  <%# Floating character images — decorative corners %>
  <img src="/hellokitty1.png" alt=""
    class="pointer-events-none select-none absolute bottom-0 left-0 w-36 md:w-48 opacity-90 drop-shadow-md" />
  <img src="/kuromi1.png" alt=""
    class="pointer-events-none select-none absolute top-4 right-0 w-28 md:w-40 opacity-90 drop-shadow-md" />
  <img src="/cinnamoroll1.png" alt=""
    class="pointer-events-none select-none absolute top-0 left-6 w-24 md:w-32 opacity-80 drop-shadow-md" />
  <img src="/melody1.png" alt=""
    class="pointer-events-none select-none absolute bottom-4 right-4 w-24 md:w-32 opacity-80 drop-shadow-md" />

  <%# Main card %>
  <div class="relative z-10 w-full max-w-md">

    <%# Sanrio Club logo + header %>
    <div class="flex flex-col items-center mb-6">
      <img src="/sanrioclub.png" alt="Sanrio Club"
        class="w-64 md:w-80 drop-shadow-lg mb-3" />
      <h1 class="text-2xl font-extrabold text-pink-600 tracking-wide">Welcome back!</h1>
      <p class="text-pink-400 text-sm mt-1">Sign in to join the fun ✨</p>
    </div>

    <% if (pageError) { %>
      <%- include("partials/error", { message: pageError }) %>
    <% } %>

    <%# Card %>
    <div class="bg-white/90 backdrop-blur-sm border-2 border-pink-200 rounded-3xl shadow-xl p-8">

      <form class="grid gap-4" method="post" action="/login">
        <div class="grid gap-1.5">
          <label for="email" class="text-sm font-bold text-pink-700">Email</label>
          <input
            id="email"
            name="email"
            type="email"
            autocomplete="username"
            required
            placeholder="you@example.com"
            class="w-full px-4 py-2.5 border-2 border-pink-200 rounded-2xl bg-pink-50 text-slate-800 placeholder:text-pink-300 focus:outline-none focus:border-pink-400 focus:bg-white transition"
          />
        </div>

        <div class="grid gap-1.5">
          <label for="password" class="text-sm font-bold text-pink-700">Password</label>
          <input
            id="password"
            name="password"
            type="password"
            autocomplete="current-password"
            required
            placeholder="••••••••"
            class="w-full px-4 py-2.5 border-2 border-pink-200 rounded-2xl bg-pink-50 text-slate-800 placeholder:text-pink-300 focus:outline-none focus:border-pink-400 focus:bg-white transition"
          />
        </div>

        <button
          type="submit"
          class="mt-1 w-full py-3 rounded-2xl bg-pink-500 text-white font-bold text-base cursor-pointer hover:bg-pink-600 active:bg-pink-700 transition shadow-md hover:shadow-lg"
        >
          Log in 🎀
        </button>
      </form>

      <div class="mt-6 pt-5 border-t-2 border-pink-100">
        <h3 class="text-sm font-bold text-pink-600 mb-3">Demo accounts</h3>
        <ul class="flex flex-col gap-2 text-xs text-slate-600">
          <li class="flex items-center gap-2 bg-pink-50 rounded-xl px-3 py-2">
            <span class="text-base">🌸</span>
            <span><code class="font-semibold text-pink-700">admin@app.test</code> · <code class="font-semibold text-pink-700">password123</code> · Admin</span>
          </li>
          <li class="flex items-center gap-2 bg-purple-50 rounded-xl px-3 py-2">
            <span class="text-base">🌙</span>
            <span><code class="font-semibold text-purple-700">staff@app.test</code> · <code class="font-semibold text-purple-700">password123</code> · Staff</span>
          </li>
          <li class="flex items-center gap-2 bg-sky-50 rounded-xl px-3 py-2">
            <span class="text-base">☁️</span>
            <span><code class="font-semibold text-sky-700">user@app.test</code> · <code class="font-semibold text-sky-700">password123</code> · User</span>
          </li>
        </ul>
      </div>
    </div>
  </div>
</div>
