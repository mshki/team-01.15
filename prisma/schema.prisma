generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}
enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
  CONCLUDED
}

enum RSVPStatus {
  YES
  NO
  WAITLIST
}

model User {
  id        String          @id @default(uuid())
  email     String          @unique
  attendees EventAttendee[]
}

model Event {
  id          Int             @id @default(autoincrement())
  title       String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  description EventDesc?
  attendees   EventAttendee[]
}

model EventDesc {
  id        Int         @id @default(autoincrement())
  eventId   Int         @unique
  event     Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  title     String
  desc      String
  location  String
  category  String
  datetime  DateTime
  organizer String
  capacity  Int
  status    EventStatus @default(DRAFT)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model EventAttendee {
  eventId   Int
  userId    String
  rsvp      RSVPStatus @default(WAITLIST)
  createdAt DateTime   @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([eventId, userId])
}
